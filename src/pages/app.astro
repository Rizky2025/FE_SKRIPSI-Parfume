---
import MainLayout from '../layouts/MainLayout.astro';

const API_BASE_URL = import.meta.env.PUBLIC_BACKEND_URL || 'http://localhost:3000';
---

<MainLayout title="Parfumerie — Rekomendasi Parfum">
  <div class="bg-[#0d0b09] text-white min-h-screen relative">

    <nav class="sticky top-0 z-[100] bg-[#0d0b09]/80 backdrop-blur-md border-b border-[#c9a96e40] py-4 px-4 md:px-8 flex justify-between items-center shadow-lg">
      <div class="text-[#c9a96e] font-bold text-lg md:text-2xl tracking-[0.2em] uppercase font-serif flex items-center gap-3">
        <i class="fa-solid fa-wand-magic-sparkles"></i> Parfumerie
      </div>
      <div class="flex items-center gap-5 md:gap-8">
        <a href="/favorites" class="text-[#ccc4b4] hover:text-[#c9a96e] transition-colors text-[10px] md:text-xs font-bold tracking-widest uppercase flex items-center gap-2">
          <i class="fa-solid fa-bookmark text-base md:text-lg"></i> <span class="hidden md:inline">Tersimpan</span>
        </a>
        <button id="btnLogout" class="text-[#ccc4b4] hover:text-red-500 transition-colors text-[10px] md:text-xs font-bold tracking-widest uppercase flex items-center gap-2 focus:outline-none">
          <i class="fa-solid fa-right-from-bracket text-base md:text-lg"></i> <span class="hidden md:inline">Logout</span>
        </button>
      </div>
    </nav>

    <div id="loadingOverlay" class="fixed inset-0 bg-[#0d0b09]/90 backdrop-blur-md z-[9999] flex flex-col items-center justify-center opacity-0 pointer-events-none transition-opacity duration-500">
      <div class="w-72 text-center">
        <i class="fa-solid fa-wand-magic-sparkles text-5xl text-[#c9a96e] mb-6 animate-pulse"></i>
        <h3 class="text-[#c9a96e] font-bold tracking-[0.2em] uppercase mb-4 text-sm">Mencari parfum...</h3>
        <div class="h-1.5 w-full bg-[#1a1713] rounded-full overflow-hidden border border-[#c9a96e40]">
          <div id="loadingBar" class="h-full bg-gradient-to-r from-[#c9a96e] to-[#f3e5ab] w-0 transition-all duration-200 ease-out"></div>
        </div>
      </div>
    </div>

    <div class="container mx-auto max-w-6xl px-4 py-8">

      <header class="text-center py-10 md:py-14 mb-10 border-b border-[#c9a96e40]">
        <h1 class="text-4xl md:text-5xl font-bold text-[#c9a96e] mb-3 tracking-tight">Pencari Parfum</h1>
        <p class="text-[#ccc4b4] text-base max-w-xl mx-auto leading-relaxed">
          Isi kebutuhanmu, sistem mencocokkan dengan deskripsi & notes parfum (TF-IDF).
        </p>
      </header>

      <section class="bg-[#1a1713] border border-[#c9a96e40] p-6 md:p-8 rounded-lg shadow-2xl mb-12">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <div class="md:col-span-2">
            <label class="block text-[#c9a96e] text-xs font-bold tracking-widest uppercase mb-2">Apa yang dicari?</label>
            <input type="text" id="userInput" placeholder="Contoh: parfum manis untuk malam hari" class="w-full bg-[#0d0b09] border border-[#c9a96e40] text-white p-4 rounded focus:border-[#c9a96e] focus:outline-none transition-all placeholder-gray-600">
          </div>
          <div>
            <label class="block text-[#c9a96e] text-xs font-bold tracking-widest uppercase mb-2">Gender</label>
            <select id="genderInput" class="w-full bg-[#0d0b09] border border-[#c9a96e40] text-white p-4 rounded focus:border-[#c9a96e] focus:outline-none transition-all appearance-none cursor-pointer">
              <option value="">Semua</option>
              <option value="pria">Pria</option>
              <option value="wanita">Wanita</option>
              <option value="unisex">Unisex</option>
            </select>
          </div>
          <div>
            <label class="block text-[#c9a96e] text-xs font-bold tracking-widest uppercase mb-2">Waktu Pemakaian</label>
            <select id="timeInput" class="w-full bg-[#0d0b09] border border-[#c9a96e40] text-white p-4 rounded focus:border-[#c9a96e] focus:outline-none transition-all appearance-none cursor-pointer">
              <option value="">Kapan saja</option>
              <option value="pagi">Pagi Hari</option>
              <option value="siang">Siang Hari</option>
              <option value="malam">Malam Hari</option>
            </select>
          </div>
          <div>
            <label class="block text-[#c9a96e] text-xs font-bold tracking-widest uppercase mb-2">Aroma Utama</label>
            <select id="vibeInput" class="w-full bg-[#0d0b09] border border-[#c9a96e40] text-white p-4 rounded focus:border-[#c9a96e] focus:outline-none transition-all appearance-none cursor-pointer">
              <option value="">Pilih karakter</option>
              <option value="woody">Woody (Kayu)</option>
              <option value="floral">Floral (Bunga)</option>
              <option value="fresh">Fresh (Segar)</option>
              <option value="sweet">Sweet (Manis)</option>
              <option value="spicy">Spicy (Rempah)</option>
            </select>
          </div>
          <div>
            <label class="block text-[#c9a96e] text-xs font-bold tracking-widest uppercase mb-2">Kegiatan</label>
            <select id="kegiatanInput" class="w-full bg-[#0d0b09] border border-[#c9a96e40] text-white p-4 rounded focus:border-[#c9a96e] focus:outline-none transition-all appearance-none cursor-pointer">
              <option value="">Bebas</option>
              <option value="Casual / Daily">Santai / Harian</option>
              <option value="Office / Formal">Kantor / Formal</option>
              <option value="Sport / Outdoor">Olahraga / Outdoor</option>
              <option value="Date / Romantic">Kencan / Romantis</option>
              <option value="Party / Night">Pesta / Malam</option>
            </select>
          </div>
        </div>
        <button id="btnCari" class="btn-gold mt-7 w-full block text-center py-4 rounded">Cari Parfum</button>
      </section>

      <div id="resultSection" class="mb-20 hidden">
        <div class="flex items-center justify-between mb-6 border-l-4 border-[#c9a96e] pl-4">
          <h2 class="text-2xl font-bold text-white m-0">Hasil Rekomendasi</h2>
          <span id="resultCount" class="text-[#ccc4b4] text-sm"></span>
        </div>
        <p id="fallbackNote" class="hidden text-[#9a8f7a] text-sm italic mb-6 -mt-3">Tidak ada yang benar-benar cocok — berikut yang paling mendekati.</p>
        <div id="resultContainer" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6"></div>
        <div class="text-center mt-10">
          <button id="btnLoadMore" class="btn-gold hidden px-8 py-3 w-max mx-auto rounded">Tampilkan Lebih Banyak</button>
        </div>
      </div>

    </div>
  </div>

  <div id="modalOverlay" class="fixed inset-0 bg-black/80 backdrop-blur-sm z-[1000] flex items-center justify-center p-4 opacity-0 pointer-events-none transition-opacity duration-300">
    <div id="modalBox" class="bg-[#0d0b09] border border-[#c9a96e40] w-full max-w-4xl rounded-lg overflow-hidden max-h-[90vh] flex flex-col relative transform scale-95 transition-transform duration-300 shadow-2xl">
      <button id="closeModal" class="absolute top-4 right-4 w-10 h-10 bg-black/60 border border-[#c9a96e40] text-white rounded-full flex items-center justify-center hover:bg-[#c9a96e] hover:text-black transition-colors z-20 shadow-lg">
        <i class="fa-solid fa-xmark text-lg"></i>
      </button>
      <div id="modalBody" class="h-full overflow-y-auto overflow-x-hidden"></div>
    </div>
  </div>

<script define:vars={{ API_BASE_URL }}>
    const AppManager = {
      state: {
        userId: null,
        favoritesMap: {},
        all: [],
        displayed: 8,
        keywords: [],
        currentModalItem: null,
      },

      async init() {
        // identitas user — login menyimpan 'user_id'; dukung format lama 'user' (JSON)
        this.state.userId = localStorage.getItem('user_id') || null;
        if (!this.state.userId) {
          const storedUser = localStorage.getItem('user');
          if (storedUser) {
            try { const p = JSON.parse(storedUser); this.state.userId = p.id || p.user_id; } catch (e) {}
          }
        }
        if (!this.state.userId) {
          let s = localStorage.getItem('sessionId');
          if (!s) { s = 'guest_' + Math.random().toString(36).substr(2, 9); localStorage.setItem('sessionId', s); }
          this.state.userId = s;
        }

        await this.loadFavorites();

        document.getElementById('btnLogout')?.addEventListener('click', () => {
          Swal.fire({
            title: 'Konfirmasi Logout', text: 'Yakin ingin keluar?', icon: 'warning',
            showCancelButton: true, background: '#1a1713', color: '#ccc4b4',
            confirmButtonColor: '#c9a96e', cancelButtonColor: '#d33', confirmButtonText: 'Ya, Logout!'
          }).then((r) => {
            if (r.isConfirmed) {
              localStorage.removeItem('user'); localStorage.removeItem('user_id'); localStorage.removeItem('access_token');
              window.location.href = '/';
            }
          });
        });

        document.getElementById('btnCari').addEventListener('click', () => this.fetchRecommendations());
        document.getElementById('btnLoadMore').addEventListener('click', () => { this.state.displayed += 8; this.render(); });
        this.setupModalListeners();
        window.AppManager = this;
      },

      async loadFavorites() {
        try {
          const res = await fetch(`${API_BASE_URL}/api/favorites/${this.state.userId}`);
          if (res.ok) {
            const data = await res.json();
            if (data.data) data.data.forEach(f => { this.state.favoritesMap[f.perfume_name] = f.id; });
          }
        } catch (e) { console.error('Gagal memuat favorit', e); }
      },

      toggleFavoriteByIndex(ev, idx, btn) {
        if (ev) ev.stopPropagation();
        const p = this.state.all[idx];
        if (p) this.toggleFavorite(btn, p);
      },

      toggleFavoriteCurrent(btn, ev) {
        if (ev) ev.stopPropagation();
        if (this.state.currentModalItem) this.toggleFavorite(btn, this.state.currentModalItem);
      },

      async toggleFavorite(btnElement, p) {
        const icon = btnElement.querySelector('i');
        const nama = p.nama || p.nama_parfum || 'Produk Tanpa Nama';
        const favId = this.state.favoritesMap[nama];
        try {
          if (favId) {
            const res = await fetch(`${API_BASE_URL}/api/favorites/${favId}`, {
              method: 'DELETE', headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ userId: this.state.userId })
            });
            if (res.ok) {
              delete this.state.favoritesMap[nama];
              icon.className = 'fa-solid fa-bookmark text-lg drop-shadow-md text-[#ccc4b4] opacity-50';
              Swal.fire({ toast: true, position: 'top-end', icon: 'info', title: 'Dihapus dari simpanan', showConfirmButton: false, timer: 1500, background: '#1a1713', color: '#ccc4b4' });
            }
          } else {
            const payload = { userId: this.state.userId, name: nama, brand: p.brand || 'Bespoke', notes: p.notes || 'Klasifikasi aroma.' };
            const res = await fetch(`${API_BASE_URL}/api/favorites`, {
              method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload)
            });
            const result = await res.json();
            if (res.ok || res.status === 201) {
              this.state.favoritesMap[nama] = result.data[0].id;
              icon.className = 'fa-solid fa-bookmark text-lg drop-shadow-md text-[#c9a96e] scale-110';
              Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: 'Tersimpan!', showConfirmButton: false, timer: 1500, background: '#1a1713', color: '#c9a96e' });
            } else {
              Swal.fire({ icon: 'error', title: 'Gagal Menyimpan', text: result.error || 'Kesalahan sistem.', background: '#1a1713', color: '#ccc4b4', confirmButtonColor: '#c9a96e' });
            }
          }
        } catch (e) { console.error('Error Favorite:', e); }
      },

      async fetchRecommendations() {
        const payload = {
          user_input: document.getElementById('userInput').value,
          gender: document.getElementById('genderInput').value,
          waktu_pemakaian: document.getElementById('timeInput').value,
          kegiatan: document.getElementById('kegiatanInput').value,
          wangi: document.getElementById('vibeInput').value,
        };

        const loadingPromise = this.showLoading();
        try {
          const res = await fetch(`${API_BASE_URL}/api/recommend`, {
            method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload)
          });
          const result = await res.json();
          await loadingPromise;

          // BE (Express) membungkus ulang jadi { cbf, cf, ... }; ML langsung pakai { data }.
          // Dukung dua-duanya, ambil CBF saja (CF sudah dimatikan).
          const data = (Array.isArray(result.cbf) && result.cbf.length)
            ? result.cbf
            : (result.data || []).filter(it => !it.tipe || it.tipe === 'CBF');
          this.state.keywords = result.kata_kunci || [];

          if (data.length === 0) {
            this.hideLoading();
            Swal.fire({ icon: 'info', title: 'Tidak Ditemukan', text: 'Coba kata kunci lain.', background: '#1a1713', color: '#ccc4b4', confirmButtonColor: '#c9a96e' });
            return;
          }

          this.state.all = data;
          this.state.displayed = 8;

          document.getElementById('resultSection').classList.remove('hidden');
          document.getElementById('resultCount').innerText = `${data.length} parfum`;
          document.getElementById('fallbackNote').classList.toggle('hidden', !result.is_fallback);

          this.hideLoading();
          this.render();
          document.getElementById('resultSection').scrollIntoView({ behavior: 'smooth', block: 'start' });
        } catch (err) {
          this.hideLoading();
          console.error('Error API:', err);
          Swal.fire({ icon: 'error', title: 'Gagal', text: 'Tidak bisa menghubungi server.', background: '#1a1713', color: '#ccc4b4', confirmButtonColor: '#c9a96e' });
        }
      },

      showLoading() {
        return new Promise(resolve => {
          const overlay = document.getElementById('loadingOverlay');
          const bar = document.getElementById('loadingBar');
          document.getElementById('resultSection').classList.add('hidden');
          overlay.classList.remove('opacity-0', 'pointer-events-none');
          bar.style.width = '0%';
          let progress = 0;
          const interval = setInterval(() => { progress = Math.min(90, progress + Math.random() * 15); bar.style.width = `${progress}%`; }, 300);
          setTimeout(() => { clearInterval(interval); bar.style.width = '100%'; resolve(); }, 1000);
        });
      },

      hideLoading() {
        setTimeout(() => { document.getElementById('loadingOverlay').classList.add('opacity-0', 'pointer-events-none'); }, 300);
      },

      render() {
        const container = document.getElementById('resultContainer');
        const toShow = this.state.all.slice(0, this.state.displayed);
        container.innerHTML = toShow.map((p, i) => this.templateCard(p, i)).join('');
        document.getElementById('btnLoadMore').classList.toggle('hidden', this.state.all.length <= this.state.displayed);
      },

      escapeHtml(s) { return String(s ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;'); },
      escapeRegex(s) { return String(s).replace(/[.*+?^${}()|[\]\\]/g, '\\$&'); },

      // utamakan kata yang benar-benar dicocokkan algoritma (bukti.kata_cocok), lalu fallback kata pencarian
      getKeywords(p) {
        if (p && p.bukti && Array.isArray(p.bukti.kata_cocok) && p.bukti.kata_cocok.length) {
          return p.bukti.kata_cocok.map(k => k.kata);
        }
        return this.state.keywords;
      },

      highlightText(text, keywords) {
        const safe = this.escapeHtml(text || '');
        const kws = (keywords || this.state.keywords || []).filter(k => k && k.length > 1);
        if (kws.length === 0) return safe;
        const pattern = [...new Set(kws)].sort((a, b) => b.length - a.length).map(k => this.escapeRegex(k)).join('|');
        return safe.replace(new RegExp(`(${pattern})`, 'gi'), '<mark class="bg-[#c9a96e]/25 text-[#c9a96e] font-bold px-1 rounded">$1</mark>');
      },

      templateCard(p, idx) {
        const nama = p.nama || p.nama_parfum || 'Produk Tanpa Nama';
        const brand = p.brand || 'Bespoke';
        const hargaNum = parseInt(p.harga) || 0;
        const harga = hargaNum > 0 ? `Rp ${hargaNum.toLocaleString('id-ID')}` : 'Cek harga di toko';
        const img = p.url_foto || 'https://images.unsplash.com/photo-1594035910387-fea47794261f?q=80&w=600&auto=format&fit=crop';
        const score = p.match_score_num != null ? `${p.match_score_num}%` : (p.match_score || '');
        const isFav = !!this.state.favoritesMap[nama];
        const bookmarkClass = isFav ? 'fa-solid text-[#c9a96e]' : 'fa-solid text-[#ccc4b4] opacity-50';

        return `
          <div class="card-parfum flex flex-col h-full relative group" onclick="AppManager.openModalByIndex(${idx})">
            <div class="absolute top-3 left-3 z-10 bg-black/80 backdrop-blur-sm border border-[#c9a96e] text-[#c9a96e] text-xs px-2 py-1 rounded shadow-lg font-bold">
              Cocok ${score}
            </div>
            <div class="h-56 overflow-hidden bg-black w-full">
              <img src="${img}" class="w-full h-full object-cover opacity-80 group-hover:opacity-100 group-hover:scale-110 transition-all duration-700" alt="${this.escapeHtml(nama)}">
            </div>
            <div class="p-4 flex flex-col flex-grow bg-[#1a1713]">
              <span class="text-[#c9a96e] text-[10px] tracking-widest uppercase font-bold mb-1 block">${this.escapeHtml(brand)}</span>
              <div class="flex justify-between items-start gap-2 mb-3">
                <h3 class="text-white text-base font-semibold line-clamp-2 leading-snug m-0">${this.escapeHtml(nama)}</h3>
                <button class="flex-shrink-0 hover:scale-110 transition-transform mt-0.5" onclick="AppManager.toggleFavoriteByIndex(event, ${idx}, this)" title="Simpan">
                  <i class="fa-bookmark text-lg drop-shadow-md transition-colors duration-300 ${bookmarkClass}"></i>
                </button>
              </div>
              <p class="text-[#ccc4b4] text-sm mt-auto border-t border-[#c9a96e40] pt-3 font-medium">${harga}</p>
            </div>
          </div>`;
      },

      // Penjelasan "kenapa sekian persen" — rincian kontribusi tiap kata dari ML (bukti.kata_cocok)
      renderReasonSection(p) {
        const kata = (p.bukti && Array.isArray(p.bukti.kata_cocok)) ? p.bukti.kata_cocok : [];
        const skor = p.match_score_num != null ? p.match_score_num : 0;

        if (!kata.length) {
          return `<div class="bg-[#1a1713] border-l-4 border-[#c9a96e] p-5 mb-6 rounded-r">
            <h4 class="text-[#c9a96e] text-xs font-bold uppercase tracking-widest mb-2">Mengapa cocok ${skor}%?</h4>
            <p class="text-[#ccc4b4] text-sm m-0">Kecocokan berasal dari kemiripan pola teks secara umum, tidak terpaku pada satu kata.</p>
          </div>`;
        }

        const rows = kata.map(k => {
          const lokasi = (k.ditemukan_di && k.ditemukan_di.length) ? k.ditemukan_di.join(', ') : 'deskripsi';
          const pct = k.kontribusi_persen != null ? k.kontribusi_persen : 0;
          return `<div class="py-2 border-b border-[#c9a96e22]">
            <div class="flex items-center justify-between gap-3 mb-1">
              <span class="text-sm"><span class="text-[#c9a96e] font-semibold">"${this.escapeHtml(k.kata)}"</span> <span class="text-[#9a8f7a] text-xs">→ di ${this.escapeHtml(lokasi)}</span></span>
              <span class="text-[#c9a96e] text-xs font-bold flex-shrink-0">${pct}%</span>
            </div>
            <div class="h-1.5 w-full bg-[#0d0b09] rounded-full overflow-hidden">
              <div class="h-full bg-gradient-to-r from-[#c9a96e] to-[#f3e5ab]" style="width:${Math.min(100, pct)}%"></div>
            </div>
          </div>`;
        }).join('');

        return `<div class="bg-[#1a1713] border-l-4 border-[#c9a96e] p-5 mb-6 rounded-r">
          <h4 class="text-[#c9a96e] text-xs font-bold uppercase tracking-widest mb-1">Mengapa cocok ${skor}%?</h4>
          <p class="text-[#ccc4b4] text-xs mb-3">Skor dihitung dari bobot kata kunci yang sama antara pencarianmu dan teks parfum ini (TF-IDF). Tiap kata menyumbang sebagian dari skor:</p>
          ${rows}
        </div>`;
      },

      setupModalListeners() {
        const closeBtn = document.getElementById('closeModal');
        const overlay = document.getElementById('modalOverlay');
        const box = document.getElementById('modalBox');
        const closeFn = () => {
          overlay.classList.add('opacity-0', 'pointer-events-none');
          box.classList.remove('scale-100'); box.classList.add('scale-95');
          setTimeout(() => { document.getElementById('modalBody').innerHTML = ''; }, 300);
        };
        closeBtn.addEventListener('click', closeFn);
        overlay.addEventListener('click', (e) => { if (e.target.id === 'modalOverlay') closeFn(); });
      },

      openModalByIndex(idx) {
        const p = this.state.all[idx];
        if (p) this.openModal(p);
      },

      openModal(p) {
        this.state.currentModalItem = p;
        const overlay = document.getElementById('modalOverlay');
        const box = document.getElementById('modalBox');
        const modalBody = document.getElementById('modalBody');

        const nama = p.nama || p.nama_parfum || 'Detail Produk';
        const deskripsi = p.deskripsi || p.description || 'Deskripsi tidak tersedia.';
        const kws = this.getKeywords(p);
        const hlNama = this.highlightText(nama, kws);
        const hlDeskripsi = this.highlightText(deskripsi, kws);

        const noteRow = (label, val) => {
          const v = String(val || '').trim();
          if (!v || v.toLowerCase() === 'n/a') return '';
          return `<div class="flex gap-2 mb-1.5"><span class="text-[#9a8f7a] text-[10px] uppercase tracking-wider w-16 flex-shrink-0 pt-1">${label}</span><span class="text-[#ccc4b4] text-sm">${this.highlightText(v, kws)}</span></div>`;
        };
        const notesHtml = noteRow('Top', p.top_notes) + noteRow('Middle', p.middle_notes) + noteRow('Base', p.base_notes) + noteRow('Accords', p.main_accords);
        const notesBlock = notesHtml || `<p class="text-[#ccc4b4] text-sm m-0">${this.highlightText(p.notes || 'Klasifikasi aroma.', kws)}</p>`;

        const link = p.link_pembelian || p.url_produk || '#';
        const img = p.url_foto || 'https://images.unsplash.com/photo-1594035910387-fea47794261f?q=80&w=600&auto=format&fit=crop';
        const brand = p.brand || 'Bespoke';
        const hargaNum = parseInt(p.harga) || 0;
        const harga = hargaNum > 0 ? `Rp ${hargaNum.toLocaleString('id-ID')}` : 'Harga tidak tersedia';
        const q = encodeURIComponent(`${brand} ${nama} parfum`);
        const isFav = !!this.state.favoritesMap[nama];
        const bookmarkClass = isFav ? 'fa-solid text-[#c9a96e]' : 'fa-solid text-[#ccc4b4] opacity-50';

        modalBody.innerHTML = `
          <div class="flex flex-col md:flex-row">
            <div class="w-full md:w-5/12 bg-black flex-shrink-0 relative">
              <img src="${img}" class="w-full h-[300px] md:h-full object-cover opacity-90" alt="${this.escapeHtml(nama)}">
              <div class="absolute inset-0 bg-gradient-to-t from-[#0d0b09] via-transparent to-transparent md:bg-gradient-to-r md:from-transparent md:to-[#0d0b09]"></div>
            </div>
            <div class="w-full md:w-7/12 p-6 md:p-8">
              <p class="text-[#c9a96e] text-xs tracking-[0.2em] uppercase font-bold mb-2">${this.escapeHtml(brand)}</p>
              <div class="flex justify-between items-start gap-4 mb-3">
                <h2 class="text-2xl md:text-3xl text-white font-bold leading-tight m-0">${hlNama}</h2>
                <button class="hover:scale-110 transition-transform flex-shrink-0 mt-1" onclick="AppManager.toggleFavoriteCurrent(this, event)" title="Simpan">
                  <i class="fa-bookmark text-2xl drop-shadow-md transition-colors duration-300 ${bookmarkClass}"></i>
                </button>
              </div>
              <p class="text-xl text-[#ccc4b4] mb-5 font-light">${harga}</p>

              <div class="grid grid-cols-3 gap-2 mb-6">
                <a href="${link}" target="_blank" rel="noopener noreferrer" class="btn-gold text-center py-2 text-[10px] flex items-center justify-center">Link Asli</a>
                <a href="https://www.tokopedia.com/search?q=${q}" target="_blank" rel="noopener noreferrer" class="bg-[#20CE71] hover:bg-[#189e56] text-white rounded text-center py-2 flex items-center justify-center gap-1 transition-colors font-bold text-xs"><i class="fa-solid fa-bag-shopping"></i> Tokopedia</a>
                <a href="https://shopee.co.id/search?keyword=${q}" target="_blank" rel="noopener noreferrer" class="bg-[#EE4D2D] hover:bg-[#c93f24] text-white rounded text-center py-2 flex items-center justify-center gap-1 transition-colors font-bold text-xs"><i class="fa-solid fa-cart-shopping"></i> Shopee</a>
              </div>

              ${this.renderReasonSection(p)}

              <div class="mb-6">
                <h4 class="text-white text-lg font-bold mb-2 border-b border-[#c9a96e40] pb-2 inline-block">Deskripsi</h4>
                <p class="text-[#ccc4b4] text-sm leading-relaxed text-justify">${hlDeskripsi}</p>
              </div>

              <div class="bg-[#1a1713] border border-[#c9a96e40] p-5 rounded">
                <strong class="text-[#c9a96e] text-xs uppercase tracking-widest block mb-3">Komposisi Aroma</strong>
                ${notesBlock}
              </div>
            </div>
          </div>`;
        overlay.classList.remove('opacity-0', 'pointer-events-none');
        box.classList.remove('scale-95'); box.classList.add('scale-100');
      }
    };

    document.addEventListener('DOMContentLoaded', () => AppManager.init());
  </script>
</MainLayout>
